# Docker Hub namespace used by docker-compose.prod.yml.
DOCKERHUB_USERNAME=marybahati

# Application/image prefix used for pushed service images e.g:
# marybahati/devops100-service-a:sha-<short-commit>
# marybahati/devops100-service-b:sha-<short-commit>
# marybahati/devops100-service-c:sha-<short-commit>
APP_NAME=devops100

# Current published deployment tag. Update after publishing a new commit.
# Example: ./scripts/deploy.sh sha-a1b2c3d
IMAGE_TAG=sha-3df3c04
